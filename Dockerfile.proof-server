# Official Midnight proof server from Node Toolkit
# The proof server is not a subcommand; we run the toolkit service directly
FROM midnightntwrk/midnight-node-toolkit:latest-main

EXPOSE 6300

# The toolkit container serves as a sidecar for proof generation
# It doesn't run a persistent server by default
# Instead, the relay service calls it for proof generation via HTTP
CMD ["sleep", "infinity"]
