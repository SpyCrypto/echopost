// Test: Private credential storage with selective disclosure
test "StoreCredentials should keep credentials private" {
  let echopost = deploy(EchoPost);
  
  let platform = "medium";
  let encryptedCred = 0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef;
  
  let witness = PrivateWitness {
    oauthCredentials: map<string, bytes>{},
    encryptionKey: 0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef,
    userSecret: 0xfedcbafedcbafedcbafedcbafedcbafedcbafedcbafedcbafedcbafedcba,
  };
  
  echopost.storeCredentials(platform, encryptedCred, witness);
  
  // Credentials should remain in private witness
  // Only platform name is disclosed via disclose()
  assert(witness.oauthCredentials[platform] == encryptedCred);
}

test "StoreCredentials should disclose platform name only" {
  let echopost = deploy(EchoPost);
  
  let platform = "linkedin";
  let encryptedCred = 0xcafebabecafebabecafebabecafebabecafebabecafebabecafebabecafebabe;
  
  let witness = PrivateWitness {
    oauthCredentials: map<string, bytes>{},
    encryptionKey: 0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890,
    userSecret: 0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef,
  };
  
  echopost.storeCredentials(platform, encryptedCred, witness);
  
  // Platform name should be disclosed (public)
  // Credentials should remain private
  assert(witness.oauthCredentials[platform] == encryptedCred);
}

test "StoreCredentials should handle multiple platforms" {
  let echopost = deploy(EchoPost);
  
  let witness = PrivateWitness {
    oauthCredentials: map<string, bytes>{},
    encryptionKey: 0x1111111111111111111111111111111111111111111111111111111111111111,
    userSecret: 0x2222222222222222222222222222222222222222222222222222222222222222,
  };
  
  echopost.storeCredentials("medium", 0xaaaabbbbccccddddeeeeffff00001111222233334444, witness);
  echopost.storeCredentials("x", 0xbbbbccccddddeeeeffff000011112222333344445555, witness);
  echopost.storeCredentials("linkedin", 0xccccddddeeeeffff0000111122223333444455556666, witness);
  
  assert(witness.oauthCredentials["medium"] == 0xaaaabbbbccccddddeeeeffff00001111222233334444);
  assert(witness.oauthCredentials["x"] == 0xbbbbccccddddeeeeffff000011112222333344445555);
  assert(witness.oauthCredentials["linkedin"] == 0xccccddddeeeeffff0000111122223333444455556666);
}

test "StoreCredentials should preserve encryption key" {
  let echopost = deploy(EchoPost);
  
  let encryptionKey = 0x9999888877776666555544443333222211110000ffffeeeeddddccccbbbbaaaa;
  
  let witness = PrivateWitness {
    oauthCredentials: map<string, bytes>{},
    encryptionKey: encryptionKey,
    userSecret: 0xaaaa5555ffff0000aaaa5555ffff0000aaaa5555ffff0000aaaa5555ffff0000,
  };
  
  echopost.storeCredentials("notion", 0x1234123412341234123412341234123412341234123412341234123412341234, witness);
  
  assert(witness.encryptionKey == encryptionKey);
}

test "StoreCredentials should preserve user secret" {
  let echopost = deploy(EchoPost);
  
  let userSecret = 0xabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd;
  
  let witness = PrivateWitness {
    oauthCredentials: map<string, bytes>{},
    encryptionKey: 0x0000111122223333444455556666777788889999aaaabbbbccccddddeeeeffff,
    userSecret: userSecret,
  };
  
  echopost.storeCredentials("devpost", 0xfeedfeedfeedfeedfeedfeedfeedfeedfeedfeedfeedfeedfeedfeedfeed, witness);
  
  assert(witness.userSecret == userSecret);
}
